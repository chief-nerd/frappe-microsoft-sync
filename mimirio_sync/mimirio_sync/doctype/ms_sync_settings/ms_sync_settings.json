{
  "name": "MS Sync Settings",
  "doctype": "DocType",
  "module": "Mimirio Sync",
  "autoname": "format:MS-SYNC-{user}",
  "fields": [
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "label": "User",
      "options": "User",
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "microsoft_list_id",
      "fieldtype": "Data",
      "label": "Microsoft List ID",
      "read_only": 1
    },
    {
      "fieldname": "calendar_sync_token",
      "fieldtype": "Data",
      "label": "Calendar Sync Token",
      "read_only": 1,
      "unique": 1
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    },
    {
      "fieldname": "pull_sync_interval",
      "fieldtype": "Int",
      "label": "Pull Sync Interval (Minutes)",
      "description": "How often to pull changes from Microsoft (0 = manual only)",
      "default": "60"
    },
    {
      "fieldname": "last_pull_datetime",
      "fieldtype": "Datetime",
      "label": "Last Pull Datetime",
      "read_only": 1
    },
    {
      "fieldname": "section_break_sync_types",
      "fieldtype": "Section Break",
      "label": "Sync Features"
    },
    {
      "fieldname": "sync_todos",
      "fieldtype": "Check",
      "label": "Sync To-Dos",
      "default": "1"
    },
    {
      "fieldname": "sync_contacts",
      "fieldtype": "Check",
      "label": "Sync Contacts",
      "default": "1"
    },
    {
      "fieldname": "sync_events",
      "fieldtype": "Check",
      "label": "Sync Events",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "if_owner": 1
    }
  ]
}
